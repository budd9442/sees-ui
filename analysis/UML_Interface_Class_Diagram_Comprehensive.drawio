                <mxCell id="legend-box" value="UML INTERFACE NOTATION:&#10;&#10;• &lt;&lt;interface&gt;&gt; = Interface&#10;• ◄─── (hollow arrow) = Implementation&#10;• ────── (plain line) = Dependency&#10;• + = Public method&#10;• - = Private field&#10;• {abstract} = Abstract method&#10;• {static} = Static method" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;align=left;verticalAlign=top;fontSize=12;fontColor=#000000;strokeWidth=2;" parent="1" vertex="1">
