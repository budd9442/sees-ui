generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id             String               @id @default(uuid())
  email               String               @unique
  username            String               @unique
  password_hash       String
  status              String               @default("ACTIVE")
  created_at          DateTime             @default(now())
  last_login_date     DateTime?
  address             String?
  avatar              String?
  bio                 String?
  emergency_contact   String?
  github              String?
  linkedin            String?
  phone               String?
  role                String               @default("student")
  firstName           String
  lastName            String
  isTwoFactorEnabled  Boolean              @default(false)
  twoFactorSecret     String?
  twoFactorBackupCodes String[]
  twoFactorConfirmation TwoFactorConfirmation?
  received_messages   Message[]            @relation("Recipient")
  sent_messages       Message[]            @relation("Sender")
  notifications       Notification[]
  staff               Staff?
  student             Student?
  passwordResetTokens                       PasswordResetToken[]
  registrationTokens                      RegistrationToken[]
  resolved_selection_change_requests        SelectionAllocationChangeRequest[] @relation("ResolvedSelectionChangeRequests")
  analytics_reports                         AnalyticsReport[]
}

model TwoFactorConfirmation {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [user_id], onDelete: Cascade)
}

model RegistrationToken {
  id         String    @id @default(cuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  created_at DateTime  @default(now())
  used       Boolean   @default(false)
  used_at    DateTime?
  user       User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
  @@map("registration_tokens")
}

model Student {
  student_id              String               @id
  admission_year          Int
  current_gpa             Float                @default(0.0)
  academic_class          String?
  metadata                Json?
  onboarding_completed_at DateTime?
  degree_path_id          String
  specialization_id       String?
  advisor_id              String?
  current_level           String?
  enrollment_status       String               @default("ENROLLED")
  graduation_status       String               @default("NOT_GRADUATED")
  graduated_at            DateTime?
  pathway_locked          Boolean              @default(false)
  pathway_preference_1_id String?
  pathway_preference_2_id String?
  pathway_selection_date  DateTime?
  academic_goals          AcademicGoal[]
  anonymous_reports       AnonymousReport[]
  gpa_history             GPAHistory[]
  grades                  Grade[]

  module_registrations    ModuleRegistration[]
  lms_import_sessions    LmsImportSession[]
  rankings                Ranking[]
  advisor                 Advisor?             @relation(fields: [advisor_id], references: [advisor_id])
  degree_path             DegreeProgram        @relation(fields: [degree_path_id], references: [program_id])
  preference_1            DegreeProgram?       @relation("PathwayPreference1", fields: [pathway_preference_1_id], references: [program_id])
  preference_2            DegreeProgram?       @relation("PathwayPreference2", fields: [pathway_preference_2_id], references: [program_id])
  specialization          Specialization?      @relation(fields: [specialization_id], references: [specialization_id])
  user                    User                 @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  selection_allocation_change_requests SelectionAllocationChangeRequest[]
  ai_feedback_snapshots    StudentAIFeedbackSnapshot[]
  recovery_snapshots       AcademicRecoverySnapshot[]
}

model StudentAIFeedbackSnapshot {
  snapshot_id                 String   @id @default(uuid())
  student_id                  String
  feedback_json               Json
  prompt_context_hash         String
  gpa_at_generation           Float
  transcript_fingerprint      String
  latest_released_grade_at    DateTime?
  generated_at                DateTime @default(now())
  expires_at                  DateTime
  source_version              String   @default("v1")
  status                      String   @default("READY")
  error_message               String?
  invalidation_reason         String?
  student                     Student  @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@index([student_id, generated_at])
  @@index([student_id, expires_at])
}

// Caches AI recovery advice per GPA dip event.
// The dip_fingerprint is "previousGPA_currentGPA" (e.g. "3.40_3.10").
model AcademicRecoverySnapshot {
  snapshot_id      String   @id @default(uuid())
  student_id       String
  dip_fingerprint  String
  previous_gpa     Float
  current_gpa      Float
  advice_json      Json
  generated_at     DateTime @default(now())
  student          Student  @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@unique([student_id, dip_fingerprint])
  @@index([student_id])
}

model Staff {
  staff_id          String            @id
  staff_number      String            @unique
  staff_type        String
  department        String
  advisor_profile   Advisor?
  hod               HOD?
  lecture_schedules LectureSchedule[]
  user              User              @relation(fields: [staff_id], references: [user_id], onDelete: Cascade)
  assignments       StaffAssignment[]
  graduation_eligibility_profiles_updated GraduationEligibilityProfile[] @relation("GraduationProfileUpdatedBy")
}

model Advisor {
  advisor_id              String    @id
  assigned_degree_path_id String?
  is_available_for_contact Boolean  @default(true)
  specialty_areas         Json?
  bio                     String?
  staff                   Staff     @relation(fields: [advisor_id], references: [staff_id], onDelete: Cascade)
  students                Student[]
}

model HOD {
  hod_id     String @id
  department String
  staff      Staff  @relation(fields: [hod_id], references: [staff_id], onDelete: Cascade)
}

model DegreeProgram {
  program_id            String                   @id @default(uuid())
  code                  String
  name                  String
  description           String?
  active                Boolean                  @default(true)
  is_common             Boolean                  @default(false)
  academic_year_id      String?
  academic_year         AcademicYear?            @relation(fields: [academic_year_id], references: [academic_year_id])
  intakes               ProgramIntake[]
  structure             ProgramStructure[]
  specializations       Specialization[]
  staff_assignments     StaffAssignment[]
  students              Student[]
  preferenced_by_1      Student[]                @relation("PathwayPreference1")
  preferenced_by_2      Student[]                @relation("PathwayPreference2")
  source_of_transitions AcademicPathTransition[] @relation("SourceProgram")
  target_of_transitions AcademicPathTransition[] @relation("TargetProgram")
  selection_configs              SelectionRoundConfig[]           @relation("ProgramSelectionConfig")
  target_selection_rounds        SelectionRound[]                 @relation("SelectionRoundTargetProgram")
  graduation_eligibility_profile GraduationEligibilityProfile?

  @@unique([code, academic_year_id])
}

model GraduationEligibilityProfile {
  profile_id          String        @id @default(uuid())
  program_id          String        @unique
  rules               Json
  version             Int           @default(1)
  updated_at          DateTime      @updatedAt
  updated_by_staff_id String?
  degree_program      DegreeProgram @relation(fields: [program_id], references: [program_id], onDelete: Cascade)
  updated_by_staff    Staff?      @relation("GraduationProfileUpdatedBy", fields: [updated_by_staff_id], references: [staff_id], onDelete: SetNull)

  @@map("graduation_eligibility_profiles")
}

model Specialization {
  specialization_id String             @id @default(uuid())
  code              String
  name              String
  active            Boolean            @default(true)
  description       String?
  program_id        String
  academic_year_id  String?
  structure         ProgramStructure[]
  academic_year     AcademicYear?      @relation(fields: [academic_year_id], references: [academic_year_id])
  degree_program    DegreeProgram      @relation(fields: [program_id], references: [program_id])
  students          Student[]
  selection_configs SelectionRoundConfig[] @relation("SpecSelectionConfig")

  @@unique([code, academic_year_id])
}

model ProgramIntake {
  intake_id        String        @id @default(uuid())
  program_id       String
  academic_year_id String
  min_students     Int           @default(0)
  max_students     Int           @default(100)
  status           String        @default("OPEN")
  academic_year    AcademicYear  @relation(fields: [academic_year_id], references: [academic_year_id])
  degree_program   DegreeProgram @relation(fields: [program_id], references: [program_id])

  @@unique([program_id, academic_year_id])
}

model Module {
  module_id            String               @id @default(uuid())
  code                 String
  name                 String
  credits              Int
  level                String
  description          String?
  active               Boolean              @default(true)
  /// When false, released grades for this module do not affect GPA (points or credits).
  counts_toward_gpa    Boolean              @default(true)
  /// Staff-editable override: [{ letter_grade, grade_point, min_marks, max_marks }]. Null = use active GradingScheme.
  custom_grading_bands Json?
  academic_year_id     String?
  grades               Grade[]
  lecture_schedules    LectureSchedule[]
  academic_year        AcademicYear?        @relation(fields: [academic_year_id], references: [academic_year_id])
  module_registrations ModuleRegistration[]
  in_programs          ProgramStructure[]
  staff_assignments    StaffAssignment[]
  Module_A             Module[]             @relation("ModulePrerequisites")
  Module_B             Module[]             @relation("ModulePrerequisites")
  academic_goals       AcademicGoal[]

  @@unique([code, academic_year_id])
}

model ProgramStructure {
  structure_id      String          @id @default(uuid())
  program_id        String
  specialization_id String?
  module_id         String
  semester_id       String?
  academic_level    String
  semester_number   Int
  module_type       String
  credits           Int?
  academic_year_id  String?
  academic_year     AcademicYear?   @relation(fields: [academic_year_id], references: [academic_year_id])
  module            Module          @relation(fields: [module_id], references: [module_id])
  degree_program    DegreeProgram   @relation(fields: [program_id], references: [program_id])
  specialization    Specialization? @relation(fields: [specialization_id], references: [specialization_id])

  @@unique([program_id, specialization_id, module_id, academic_year_id])
}

model StaffAssignment {
  assignment_id    String         @id @default(uuid())
  staff_id         String
  program_id       String?
  module_id        String?
  role             String
  assigned_at      DateTime       @default(now())
  active           Boolean        @default(true)
  academic_year_id String?
  academic_year    AcademicYear?  @relation(fields: [academic_year_id], references: [academic_year_id])
  module           Module?        @relation(fields: [module_id], references: [module_id])
  degree_program   DegreeProgram? @relation(fields: [program_id], references: [program_id])
  staff            Staff          @relation(fields: [staff_id], references: [staff_id])

  @@unique([staff_id, module_id, academic_year_id])
}

model AcademicYear {
  academic_year_id  String               @id @default(uuid())
  label             String               @unique
  start_date        DateTime
  end_date          DateTime
  active            Boolean              @default(true)
  programs          DegreeProgram[]
  grading_schemes   GradingScheme[]
  modules           Module[]
  intakes           ProgramIntake[]
  structures        ProgramStructure[]
  semesters         Semester[]
  specializations   Specialization[]
  staff_assignments StaffAssignment[]
  credit_rules               AcademicCreditRule[]
  selection_rounds           SelectionRound[]
  module_registration_rounds ModuleRegistrationRound[]
}

model Semester {
  semester_id          String               @id @default(uuid())
  academic_year_id     String
  label                String
  start_date           DateTime
  end_date             DateTime
  grades               Grade[]
  module_registrations ModuleRegistration[]
  academic_year        AcademicYear         @relation(fields: [academic_year_id], references: [academic_year_id])
}

model AcademicPathTransition {
  id                String        @id @default(uuid())
  source_program_id String
  target_program_id String
  level             String        @default("L2")
  created_at        DateTime      @default(now())
  source_program    DegreeProgram @relation("SourceProgram", fields: [source_program_id], references: [program_id])
  target_program    DegreeProgram @relation("TargetProgram", fields: [target_program_id], references: [program_id])

  @@unique([source_program_id, target_program_id, level])
  @@map("academic_path_transitions")
}

model ModuleRegistration {
  reg_id            String   @id @default(uuid())
  student_id        String
  module_id         String
  semester_id       String
  term              String?
  registration_date DateTime @default(now())
  status            String   @default("REGISTERED")
  grade             Grade?
  module            Module   @relation(fields: [module_id], references: [module_id])
  semester          Semester @relation(fields: [semester_id], references: [semester_id])
  student           Student  @relation(fields: [student_id], references: [student_id])

  @@index([semester_id, status])
}

model Grade {
  grade_id            String             @id @default(uuid())
  reg_id              String             @unique
  student_id          String
  module_id           String
  semester_id         String
  marks               Float?
  grade_point         Float
  letter_grade        String
  attempt_no          Int                @default(1)
  released_at         DateTime?
  module              Module             @relation(fields: [module_id], references: [module_id])
  module_registration ModuleRegistration @relation(fields: [reg_id], references: [reg_id])
  semester            Semester           @relation(fields: [semester_id], references: [semester_id])
  student             Student            @relation(fields: [student_id], references: [student_id])

  @@index([released_at])
}

model LmsImportSession {
  session_id    String   @id @default(uuid())
  student_id    String
  status        String   @default("RUNNING")
  stage         String   @default("LOGIN")
  progress_pct  Int      @default(0)
  preview_json  Json?
  error_message String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  student Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@index([student_id, created_at])
}

model GradingScheme {
  scheme_id        String        @id @default(uuid())
  name             String
  version          String
  active           Boolean       @default(true)
  academic_year_id String?
  bands            GradingBand[]
  academic_year    AcademicYear? @relation(fields: [academic_year_id], references: [academic_year_id])
}

model GradingBand {
  band_id        String        @id @default(uuid())
  scheme_id      String
  min_marks      Float
  max_marks      Float
  grade_point    Float
  letter_grade   String
  grading_scheme GradingScheme @relation(fields: [scheme_id], references: [scheme_id])
}

model AcademicCreditRule {
  id               String        @id @default(uuid())
  level            String
  semester_number  Int
  min_credits      Int           @default(12)
  max_credits      Int           @default(24)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  academic_year_id String?
  academic_year    AcademicYear? @relation(fields: [academic_year_id], references: [academic_year_id])

  @@unique([level, semester_number, academic_year_id])
  @@map("academic_credit_rules")
}

model GPAHistory {
  gpa_history_id   String   @id @default(uuid())
  student_id       String
  calculation_date DateTime @default(now())
  gpa              Float
  academic_class   String?
  student          Student  @relation(fields: [student_id], references: [student_id])

  @@index([calculation_date])
}

model AcademicGoal {
  goal_id      String    @id @default(uuid())
  student_id   String
  goal_type    String    @default("GPA_TARGET")
  metric_unit  String    @default("GPA")
  target_value_number Float?
  baseline_value Float?
  module_id    String?
  target_gpa   Float?
  target_class String?
  created_at   DateTime  @default(now())
  achieved_at  DateTime?
  category     String    @default("academic")
  deadline     DateTime?
  description  String?
  milestones   String[]
  priority     String    @default("medium")
  progress     Int       @default(0)
  status       String    @default("IN_PROGRESS")
  target_value String?
  title        String    @default("Academic Goal")
  student      Student   @relation(fields: [student_id], references: [student_id])
  module       Module?   @relation(fields: [module_id], references: [module_id], onDelete: SetNull)

  @@index([student_id, status])
  @@index([student_id, goal_type])
}

model Ranking {
  ranking_id       String   @id @default(uuid())
  student_id       String
  degree_path_id   String
  rank             Int
  gpa              Float
  weighted_average Float
  created_at       DateTime @default(now())
  student          Student  @relation(fields: [student_id], references: [student_id])
}

model Message {
  message_id   String    @id @default(uuid())
  sender_id    String
  recipient_id String
  subject      String
  content      String
  sent_at      DateTime  @default(now())
  read_at      DateTime?
  recipient    User      @relation("Recipient", fields: [recipient_id], references: [user_id])
  sender       User      @relation("Sender", fields: [sender_id], references: [user_id])

  @@index([recipient_id, read_at])
  @@index([recipient_id, sent_at])
  @@index([sender_id, sent_at])
}

model Notification {
  notification_id String    @id @default(uuid())
  user_id         String
  type            String
  title           String
  content         String
  sent_at         DateTime  @default(now())
  read_at         DateTime?
  user            User      @relation(fields: [user_id], references: [user_id])
}

/// Admin-configurable transactional email templates (event-driven).
model NotificationEmailTemplate {
  template_id String   @id @default(uuid())
  name         String
  event_key    String
  subject      String
  body         String   @db.Text
  placeholders Json?
  is_active    Boolean  @default(true)
  channel      String   @default("email")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([event_key])
  @@map("notification_email_templates")
}

/// Per-event enable/disable and optional JSON options (e.g. days-before for reminders).
model NotificationTriggerConfig {
  config_id   String   @id @default(uuid())
  event_key   String   @unique
  enabled     Boolean  @default(true)
  config_json Json?
  updated_at  DateTime @updatedAt

  @@map("notification_trigger_configs")
}

/// Idempotent send audit log (dedupe_key prevents duplicate deliveries).
model NotificationDispatchLog {
  log_id            String   @id @default(cuid())
  dedupe_key        String   @unique
  event_key         String
  recipient_email   String
  recipient_user_id String?
  entity_type       String?
  entity_id         String?
  status            String
  error_message     String?
  created_at        DateTime @default(now())

  @@index([event_key, created_at])
  @@map("notification_dispatch_logs")
}

model AnonymousReport {
  report_id    String          @id @default(uuid())
  student_id   String
  subject      String?
  category_id  String?
  content      String          @db.Text
  priority     String
  status       String          @default("PENDING")
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
  admin_notes  String?         @db.Text
  assigned_to  String?
  category     ReportCategory? @relation(fields: [category_id], references: [id])
  student      Student         @relation(fields: [student_id], references: [student_id])

  @@map("anonymous_reports")
}

model ReportCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  assigned_to String? // user_id of staff/admin
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  reports     AnonymousReport[]

  @@map("report_categories")
}


model LectureSchedule {
  schedule_id String   @id @default(uuid())
  module_id   String
  staff_id    String
  day_of_week String
  start_time  DateTime
  end_time    DateTime
  location    String?
  module      Module   @relation(fields: [module_id], references: [module_id])
  staff       Staff    @relation(fields: [staff_id], references: [staff_id])
}

model SystemMetric {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now()) @db.Timestamptz(6)
  cpu             Int
  cores           Int
  memory          Int
  storage_used    Float
  storage_total   Float
  storage_percent Int
  uptime          Float
  health          Int
  active_users    Int

  @@index([timestamp])
  @@map("system_metrics")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  created_at DateTime  @default(now())
  used       Boolean   @default(false)
  used_at    DateTime?
  user       User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
  @@map("password_reset_tokens")
}

model FeatureFlag {
  id          String    @id @default(uuid())
  key         String    @unique
  name        String
  description String?
  isEnabled   Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?
  targetRoles String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("feature_flags")
}

model CalendarEvent {
  id                String   @id @default(uuid())
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime
  type              String
  isRecurring       Boolean  @default(false)
  recurrencePattern String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("calendar_events")
}

model BulkEnrollmentBatch {
  batch_id           String                 @id @default(uuid())
  uploaded_by        String
  filename           String
  program_id         String?
  level              String?
  total_records      Int                    @default(0)
  successful_records Int                    @default(0)
  failed_records     Int                    @default(0)
  status             String                 @default("PROCESSING")
  created_at         DateTime               @default(now())
  records            BulkEnrollmentRecord[]

  @@map("bulk_enrollment_batches")
}

model BulkEnrollmentRecord {
  record_id          String              @id @default(uuid())
  batch_id           String
  email              String
  role               String              @default("student")
  user_id            String?
  status             String              @default("PENDING")
  error_message      String?
  email_sent         Boolean             @default(false)
  email_sent_at      DateTime?
  email_resend_count Int                 @default(0)
  last_email_sent_at DateTime?
  created_at         DateTime            @default(now())
  firstName          String
  lastName           String
  batch              BulkEnrollmentBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)

  @@index([batch_id])
  @@index([email])
  @@index([status])
  @@map("bulk_enrollment_records")
}


model SystemSetting {
  setting_id  String   @id
  key         String   @unique
  value       String
  description String?
  category    String
  updated_at  DateTime
}

model AuditLog {
  log_id      String   @id @default(uuid())
  /// Actor user_id; null for anonymous/system events (e.g. failed login, worker email).
  admin_id    String?
  action      String
  entity_type String
  entity_id   String
  old_value   String?
  new_value   String?
  timestamp   DateTime @default(now())
  /// AUTH | EMAIL | ADMIN | STAFF | SYSTEM
  category    String   @default("ADMIN")
  metadata    Json?
  ip_address  String?
  user_agent  String?  @db.Text

  @@index([timestamp])
  @@index([admin_id])
  @@index([category])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Selection Round System
// ─────────────────────────────────────────────────────────────

model SelectionRound {
  round_id         String                 @id @default(uuid())
  academic_year_id String
  type             String                 // "PATHWAY" | "SPECIALIZATION"
  label            String
  level            String?                // "L1" | "L2" | "L3" (nullable when targeting by program only)
  target_program_id String?
  status           String                 @default("DRAFT") // DRAFT | OPEN | CLOSED | APPROVED
  selection_mode   String                 @default("AUTO")  // "AUTO" | "GPA" | "FREE" — AUTO: GPA only when a pathway slot is oversubscribed
  opens_at         DateTime?
  closes_at        DateTime?
  created_at       DateTime               @default(now())
  approved_at      DateTime?
  notes            String?
  /// Days after approval during which students may submit allocation change requests (0 = none).
  allocation_change_grace_days Int            @default(0)
  configs          SelectionRoundConfig[]
  applications     SelectionApplication[]
  allocation_change_requests SelectionAllocationChangeRequest[]
  academic_year    AcademicYear           @relation(fields: [academic_year_id], references: [academic_year_id])
  target_program   DegreeProgram?         @relation("SelectionRoundTargetProgram", fields: [target_program_id], references: [program_id])

  @@index([target_program_id])
  @@map("selection_rounds")
}

model SelectionRoundConfig {
  config_id      String          @id @default(uuid())
  round_id       String
  program_id     String?         // for PATHWAY rounds
  spec_id        String?         // for SPECIALIZATION rounds
  capacity       Int             @default(50) // max (pathway) or min threshold (specialization)
  priority       Int             @default(0)
  round          SelectionRound  @relation(fields: [round_id], references: [round_id], onDelete: Cascade)
  program        DegreeProgram?  @relation("ProgramSelectionConfig", fields: [program_id], references: [program_id])
  specialization Specialization? @relation("SpecSelectionConfig", fields: [spec_id], references: [specialization_id])

  @@map("selection_round_configs")
}

model SelectionApplication {
  app_id        String         @id @default(uuid())
  round_id      String
  student_id    String
  preference_1  String         // program_id or spec_id
  preference_2  String?
  status        String         @default("PENDING") // PENDING | ALLOCATED | WAITLISTED | REJECTED
  allocated_to  String?        // program_id or spec_id that was finally allocated
  waitlist_pos  Int?           // position in waitlist (null if not waitlisted)
  gpa_at_time   Float          @default(0.0)
  applied_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  round         SelectionRound @relation(fields: [round_id], references: [round_id], onDelete: Cascade)

  @@unique([round_id, student_id])
  @@index([round_id])
  @@index([student_id])
  @@map("selection_applications")
}

model SelectionAllocationChangeRequest {
  request_id               String   @id @default(uuid())
  round_id                 String
  student_id               String
  requested_preference_1   String
  requested_preference_2   String?
  reason                   String?
  status                   String   @default("PENDING") // PENDING | APPROVED | REJECTED
  created_at               DateTime @default(now())
  resolved_at              DateTime?
  resolved_by_user_id      String?

  round       SelectionRound @relation(fields: [round_id], references: [round_id], onDelete: Cascade)
  student     Student        @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  resolved_by User?          @relation("ResolvedSelectionChangeRequests", fields: [resolved_by_user_id], references: [user_id])

  @@index([round_id])
  @@index([student_id])
  @@index([status])
  @@map("selection_allocation_change_requests")
}

// ─────────────────────────────────────────────────────────────
// Module registration rounds (HOD-managed windows)
// ─────────────────────────────────────────────────────────────

model ModuleRegistrationRound {
  round_id         String       @id @default(uuid())
  academic_year_id String
  label            String
  status           String       @default("DRAFT") // DRAFT | OPEN | CLOSED | FINALIZED
  opens_at         DateTime?
  closes_at        DateTime?
  levels           String[]     @default([]) // empty = all levels (e.g. L1, L2)
  notes            String?
  student_message  String?
  features         Json?
  finalized_at     DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  academic_year    AcademicYear @relation(fields: [academic_year_id], references: [academic_year_id], onDelete: Cascade)

  @@index([academic_year_id])
  @@index([status])
  @@map("module_registration_rounds")
}

model AnalyticsReport {
  report_id      String   @id @default(uuid())
  owner_user_id  String
  scope_role     String
  title          String
  definition     Json
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  owner          User     @relation(fields: [owner_user_id], references: [user_id], onDelete: Cascade)

  @@index([owner_user_id])
  @@index([scope_role])
  @@map("analytics_reports")
}
